{
  "name": "marketpro",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:admin": "turbo dev --filter=@marketpro/admin",
    "dev:client": "turbo dev --filter=@marketpro/client",
    "build:admin": "turbo build --filter=@marketpro/admin",
    "build:client": "turbo build --filter=@marketpro/client"
  },
  "dependencies": {
    "tailwindcss": "4.2.1",
    "@tailwindcss/postcss": "4.2.1",
    "postcss": "8.5.3"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
