# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron Jobs Authentication
CRON_SECRET=any-secret-string-you-choose

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# ============================================================
# NOTE: All API keys (Anthropic, Meta, TikTok, X, Snapchat,
# LinkedIn, YouTube, Google Ads) are now stored in the database
# and managed through the Settings page in the admin dashboard.
